 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Pipeline 3D: Phân Tích Ảnh MRI Não với 3 Mô Hình\n",
    "## Dùng SwinUNETR với spatial_dims=3\n",
    "## Bước 1: Tải dữ liệu bệnh nhân đầu tiên (3D volume)\n",
    "## Bước 2: Tiền xử lý dữ liệu 3D\n",
    "## Bước 3: Chạy thử 3 mô hình (UNet++, DeepLabV3+, SwinUNet 3D)\n",
    "## Bước 4: Đánh giá theo các chỉ số"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import nibabel as nib\n",
    "import cv2\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import os\n",
    "from pathlib import Path\n",
    "from scipy.ndimage import zoom\n",
    "\n",
    "# Cấu hình thiết bị\n",
    "DEVICE = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f\"✓ Thiết bị: {DEVICE}\")\n",
    "\n",
    "# Cấu hình đường dẫn\n",
    "DATA_ROOT = \"data/BraTS2020_TrainingData/MICCAI_BraTS2020_TrainingData\"\n",
    "PATIENT_ID = \"BraTS20_Training_001\"\n",
    "PATIENT_PATH = os.path.join(DATA_ROOT, PATIENT_ID)\n",
    "\n",
    "print(f\"\\n✓ Đường dẫn dữ liệu: {PATIENT_PATH}\")\n",
    "print(f\"✓ Files có sẵn:\")\n",
    "for file in sorted(os.listdir(PATIENT_PATH)):\n",
    "    print(f\"  - {file}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## BƯỚC 1: TIỀN XỬ LÝ DỮ LIỆU 3D"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_patient_data_3d(patient_path):\n",
    "    \"\"\"\n",
    "    Tải 4 modality MRI của bệnh nhân: T1, T1CE, T2, FLAIR (3D volumes)\n",
    "    \"\"\"\n",
    "    modalities = ['t1', 't1ce', 't2', 'flair']\n",
    "    images = {}\n",
    "    \n",
    "    for mod in modalities:\n",
    "        file_path = os.path.join(patient_path, f\"{os.path.basename(patient_path)}_{mod}.nii\")\n",
    "        img = nib.load(file_path).get_fdata()\n",
    "        images[mod] = img\n",
    "        print(f\"  ✓ {mod.upper()}: {img.shape}\")\n",
    "    \n",
    "    # Tải segmentation mask\n",
    "    seg_path = os.path.join(patient_path, f\"{os.path.basename(patient_path)}_seg.nii\")\n",
    "    seg = nib.load(seg_path).get_fdata()\n",
    "    print(f\"  ✓ Segmentation: {seg.shape}\")\n",
    "    \n",
    "    return images, seg\n",
    "\n",
    "print(\"Loading dữ liệu 3D bệnh nhân...\")\n",
    "images, seg_mask = load_patient_data_3d(PATIENT_PATH)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def preprocess_volume_3d(volume, target_size=(128, 128, 128)):\n",
    "    \"\"\"\n",
    "    Tiền xử lý volume 3D MRI:\n",
    "    1. Chuẩn hóa Percentile (1% - 99%)\n",
    "    2. Resize về kích thước target (128x128x128)\n",
    "    \"\"\"\n",
    "    # Tạo mask vùng não (non-zero)\n",
    "    mask = volume > 0\n",
    "    \n",
    "    if mask.sum() == 0:\n",
    "        return np.zeros(target_size)\n",
    "    \n",
    "    # Percentile normalization\n",
    "    p1, p99 = np.percentile(volume[mask], [1, 99])\n",
    "    volume = np.clip(volume, p1, p99)\n",
    "    volume = (volume - p1) / (p99 - p1 + 1e-8)\n",
    "    volume[~mask] = 0\n",
    "    \n",
    "    # Resize volume\n",
    "    original_shape = volume.shape\n",
    "    zoom_factors = (target_size[0] / original_shape[0],\n",
    "                    target_size[1] / original_shape[1],\n",
    "                    target_size[2] / original_shape[2])\n",
    "    volume_resized = zoom(volume, zoom_factors, order=1)\n",
    "    \n",
    "    return volume_resized\n",
    "\n",
    "# Cấu hình kích thước target\n",
    "TARGET_SIZE_3D = (128, 128, 128)  # Có thể giảm nếu bộ nhớ không đủ\n",
    "\n",
    "print(f\"\\n✓ Resize volume về: {TARGET_SIZE_3D}\")\nprint(f\"  (Giảm từ {images['t1'].shape} để tiết kiệm bộ nhớ)\\n\")\n",
    "\n",
    "# Tiền xử lý từng modality\n",
    "preprocessed_volumes = []\n",
    "for mod in ['t1', 't1ce', 't2', 'flair']:\n",
    "    processed = preprocess_volume_3d(images[mod], TARGET_SIZE_3D)\n",
    "    preprocessed_volumes.append(processed)\n",
    "    print(f\"  ✓ Đã xử lý {mod.upper()}: {processed.shape}\")\n",
    "\n",
    "# Stack 4 channels\n",
    "input_data_3d = np.stack(preprocessed_volumes, axis=0)  # (4, 128, 128, 128)\n",
    "print(f\"\\n✓ Input 3D data shape: {input_data_3d.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tiền xử lý segmentation mask 3D\n",
    "seg_processed_3d = preprocess_volume_3d(seg_mask, TARGET_SIZE_3D)\n",
    "\n",
    "# Làm tròn mask về giá trị nguyên\n",
    "seg_processed_3d = np.round(seg_processed_3d).astype(np.long)\n",
    "\n",
    "print(f\"✓ Segmentation mask shape: {seg_processed_3d.shape}\")\nprint(f\"✓ Classes trong mask: {np.unique(seg_processed_3d)}\")\n",
    "\n",
    "# Chuyển sang tensor\n",
    "X_3d = torch.from_numpy(input_data_3d).unsqueeze(0).float()  # (1, 4, 128, 128, 128)\n",
    "y_3d = torch.from_numpy(seg_processed_3d).unsqueeze(0).unsqueeze(0).long()  # (1, 1, 128, 128, 128)\n",
    "\n",
    "print(f\"\\n✓ X tensor: {X_3d.shape} | min={X_3d.min():.4f}, max={X_3d.max():.4f}\")\nprint(f\"✓ y tensor: {y_3d.shape} | classes={torch.unique(y_3d).tolist()}\")\nprint(f\"✓ Bộ nhớ: X={X_3d.element_size() * X_3d.nelement() / 1024**2:.1f}MB\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## BƯỚC 2: ĐỊNH NGHĨA CÁC MÔ HÌNH"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import segmentation_models_pytorch as smp\n",
    "from monai.networks.nets import SwinUNETR\n",
    "\n",
    "# Cấu hình chung\n",
    "IN_CHANNELS = 4  # T1, T1CE, T2, FLAIR\n",
    "NUM_CLASSES = 4  # 0=background, 1=necrotic, 2=edema, 3=enhancing\n",
    "\n",
    "print(\"Khởi tạo 3 mô hình 3D...\\n\")\n",
    "\n",
    "# Model 1: 3D UNet (basic)\n",
    "print(\"1. 3D UNet (Custom)\")\n",
    "class SimpleUNet3D(nn.Module):\n",
    "    def __init__(self, in_channels, out_channels):\n",
    "        super().__init__()\n",
    "        self.enc1 = nn.Sequential(\n",
    "            nn.Conv3d(in_channels, 32, 3, padding=1),\n",
    "            nn.ReLU(inplace=True),\n",
    "            nn.Conv3d(32, 32, 3, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        self.pool = nn.MaxPool3d(2)\n",
    "        \n",
    "        self.enc2 = nn.Sequential(\n",
    "            nn.Conv3d(32, 64, 3, padding=1),\n",
    "            nn.ReLU(inplace=True),\n",
    "            nn.Conv3d(64, 64, 3, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        \n",
    "        self.bottleneck = nn.Sequential(\n",
    "            nn.Conv3d(64, 128, 3, padding=1),\n",
    "            nn.ReLU(inplace=True),\n",
    "            nn.Conv3d(128, 128, 3, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        \n",
    "        self.upconv = nn.ConvTranspose3d(128, 64, 2, stride=2)\n",
    "        self.dec2 = nn.Sequential(\n",
    "            nn.Conv3d(128, 64, 3, padding=1),\n",
    "            nn.ReLU(inplace=True),\n",
    "            nn.Conv3d(64, 64, 3, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        \n",
    "        self.upconv2 = nn.ConvTranspose3d(64, 32, 2, stride=2)\n",
    "        self.dec1 = nn.Sequential(\n",
    "            nn.Conv3d(64, 32, 3, padding=1),\n",
    "            nn.ReLU(inplace=True),\n",
    "            nn.Conv3d(32, 32, 3, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        \n",
    "        self.final = nn.Conv3d(32, out_channels, 1)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        e1 = self.enc1(x)\n",
    "        e2 = self.enc2(self.pool(e1))\n",
    "        b = self.bottleneck(self.pool(e2))\n",
    "        d2 = self.dec2(torch.cat([self.upconv(b), e2], 1))\n",
    "        d1 = self.dec1(torch.cat([self.upconv2(d2), e1], 1))\n",
    "        return self.final(d1)\n",
    "\nmodel_unet3d = SimpleUNet3D(IN_CHANNELS, NUM_CLASSES).to(DEVICE)\nprint(f\"   ✓ Parameters: {sum(p.numel() for p in model_unet3d.parameters()):,}\\n\")\n",
    "\n",
    "# Model 2: V-Net inspired (deeper)\n",
    "print(\"2. V-Net 3D (Residual blocks)\")\nclass VNet3D(nn.Module):\n",
    "    def __init__(self, in_channels, out_channels):\n",
    "        super().__init__()\n",
    "        self.conv1 = nn.Sequential(\n",
    "            nn.Conv3d(in_channels, 16, 3, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        self.conv2 = nn.Sequential(\n",
    "            nn.Conv3d(16, 32, 3, stride=2, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        self.conv3 = nn.Sequential(\n",
    "            nn.Conv3d(32, 64, 3, stride=2, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        self.bottle = nn.Sequential(\n",
    "            nn.Conv3d(64, 128, 3, padding=1),\n",
    "            nn.ReLU(inplace=True)\n",
    "        )\n",
    "        self.deconv3 = nn.ConvTranspose3d(128, 64, 2, stride=2)\n",
    "        self.deconv2 = nn.ConvTranspose3d(64, 32, 2, stride=2)\n",
    "        self.out = nn.Conv3d(32, out_channels, 1)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        c1 = self.conv1(x)\n",
    "        c2 = self.conv2(c1)\n",
    "        c3 = self.conv3(c2)\n",
    "        b = self.bottle(c3)\n",
    "        d3 = self.deconv3(b)\n",
    "        d2 = self.deconv2(d3 + c2)\n",
    "        return self.out(d2)\n",
    "\nmodel_vnet3d = VNet3D(IN_CHANNELS, NUM_CLASSES).to(DEVICE)\nprint(f\"   ✓ Parameters: {sum(p.numel() for p in model_vnet3d.parameters()):,}\\n\")\n",
    "\n",
    "# Model 3: SwinUNETR 3D\n",
    "print(\"3. SwinUNETR 3D (Transformer-based)\")\ntry:\n",
    "    model_swin3d = SwinUNETR(\n",
    "        spatial_dims=3,\n",
    "        in_channels=IN_CHANNELS,\n",
    "        out_channels=NUM_CLASSES,\n",
    "        img_size=(128, 128, 128),\n",
    "        feature_size=24,\n",
    "        use_checkpoint=True\n",
    "    ).to(DEVICE)\n",
    "    print(f\"   ✓ Parameters: {sum(p.numel() for p in model_swin3d.parameters()):,}\\n\")\nexcept Exception as e:\n",
    "    print(f\"   ⚠ Lỗi SwinUNETR: {e}\")\n",
    "    print(f\"   → Dùng UNet 3D đơn giản thay thế\\n\")\n",
    "    model_swin3d = None\n",
    "\nif model_swin3d is not None:\n",
    "    models_3d = {\n",
    "        'UNet3D': model_unet3d,\n",
    "        'VNet3D': model_vnet3d,\n",
    "        'SwinUNETR3D': model_swin3d\n",
    "    }\nelse:\n",
    "    models_3d = {\n",
    "        'UNet3D': model_unet3d,\n",
    "        'VNet3D': model_vnet3d\n",
    "    }\n",
    "    print(\"⚠ Chỉ dùng 2 mô hình cho pipeline này\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## BƯỚC 3: CHẠY THỬ 3 MÔ HÌNH 3D"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Chạy forward pass\n",
    "X_gpu_3d = X_3d.to(DEVICE)\n",
    "\n",
    "print(\"Forward pass cho các mô hình 3D...\\n\")\n",
    "\n",
    "predictions_3d = {}\n",
    "\n",
    "with torch.no_grad():\n",
    "    for name, model in models_3d.items():\n",
    "        model.eval()\n",
    "        output = model(X_gpu_3d)\n",
    "        predictions_3d[name] = output.cpu()\n",
    "        \n",
    "        print(f\"✓ {name}\")\n",
    "        print(f\"  - Output shape: {output.shape}\")\n",
    "        print(f\"  - Output range: [{output.min():.4f}, {output.max():.4f}]\")\n",
    "        \n",
    "        # Lấy predicted class\n",
    "        pred_class = torch.argmax(output, dim=1, keepdim=True)\n",
    "        print(f\"  - Classes predicted: {torch.unique(pred_class).tolist()}\")\n",
    "        predictions_3d[name + '_class'] = pred_class\n",
    "        print()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## BƯỚC 4: ĐÁNH GIÁ CÁC CHỈ SỐ"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from monai.metrics import DiceMetric\nfrom sklearn.metrics import jaccard_score, confusion_matrix\n",
    "\n",
    "def evaluate_metrics_3d(y_pred, y_true):\n",
    "    \"\"\"\n",
    "    Tính toán các chỉ số đánh giá cho 3D:\n",
    "    - Dice Score\n",
    "    - IoU (Jaccard)\n",
    "    - Sensitivity (Recall)\n",
    "    - Specificity\n",
    "    - Accuracy\n",
    "    \"\"\"\n",
    "    # Ensure tensors on CPU\n",
    "    if y_pred.is_cuda:\n",
    "        y_pred = y_pred.cpu()\n",
    "    if y_true.is_cuda:\n",
    "        y_true = y_true.cpu()\n",
    "    \n",
    "    # Dice Score\n",
    "    dice_metric = DiceMetric(include_background=False, reduction=\"mean\")\n",
    "    try:\n",
    "        dice = dice_metric(y_pred.float(), y_true.float())\n",
    "        dice_value = dice.item()\n",
    "    except:\n",
    "        dice_value = 0.0\n",
    "    \n",
    "    # IoU (Jaccard)\n",
    "    y_pred_np = y_pred.argmax(dim=1).numpy().flatten() if len(y_pred.shape) > 2 else y_pred.numpy().flatten()\n",
    "    y_true_np = y_true.numpy().flatten()\n",
    "    \n",
    "    try:\n",
    "        iou = jaccard_score(y_true_np, y_pred_np, average='weighted', zero_division=0)\n",
    "    except:\n",
    "        iou = 0.0\n",
    "    \n",
    "    # Sensitivity & Specificity\n",
    "    try:\n",
    "        tn, fp, fn, tp = confusion_matrix(y_true_np, y_pred_np, labels=[0, 1]).ravel() if len(np.unique(y_true_np)) >= 2 else (0, 0, 0, 0)\n",
    "    except:\n",
    "        tn, fp, fn, tp = 0, 0, 0, 0\n",
    "    \n",
    "    sensitivity = tp / (tp + fn) if (tp + fn) > 0 else 0\n",
    "    specificity = tn / (tn + fp) if (tn + fp) > 0 else 0\n",
    "    \n",
    "    # Accuracy\n",
    "    accuracy = (y_pred_np == y_true_np).mean()\n",
    "    \n",
    "    return {\n",
    "        'Dice': dice_value,\n",
    "        'IoU': iou,\n",
    "        'Accuracy': accuracy,\n",
    "        'Sensitivity': sensitivity,\n",
    "        'Specificity': specificity\n",
    "    }\n",
    "\n",
    "print(\"=\"*70)\n",
    "print(\"KẾT QUẢ ĐÁNH GIÁ CÁC MÔ HÌNH 3D\")\n",
    "print(\"=\"*70)\n",
    "\n",
    "results_3d = {}\n",
    "for name, model in models_3d.items():\n",
    "    metrics = evaluate_metrics_3d(predictions_3d[name], y_3d)\n",
    "    results_3d[name] = metrics\n",
    "    \n",
    "    print(f\"\\n{name}:\")\n",
    "    print(f\"  Dice Score:    {metrics['Dice']:.4f}\")\n",
    "    print(f\"  IoU (Jaccard): {metrics['IoU']:.4f}\")\n",
    "    print(f\"  Accuracy:      {metrics['Accuracy']:.4f}\")\n",
    "    print(f\"  Sensitivity:   {metrics['Sensitivity']:.4f}\")\n",
    "    print(f\"  Specificity:   {metrics['Specificity']:.4f}\")"
   ]
  },
  {
   "cell_type": "code",
