    "# Bảng so sánh\n",
    "import pandas as pd\n",
    "\n",
    "df_results_3d = pd.DataFrame(results_3d).T\n",
    "print(\"\\n\" + \"=\"*70)\n",
    "print(\"BẢNG SO SÁNH CÁC MÔ HÌNH 3D\")\n",
    "print(\"=\"*70)\n",
    "print(df_results_3d.to_string())\n",
    "print(\"\\n✓ Mô hình tốt nhất (Dice):\")\n",
    "best_model_3d = df_results_3d['Dice'].idxmax()\n",
    "print(f\"  → {best_model_3d} với Dice={df_results_3d.loc[best_model_3d, 'Dice']:.4f}\")"
   ]
